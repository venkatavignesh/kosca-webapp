<%
var arModules = locals.user && locals.user.modules ? locals.user.modules : [];
var hasAR = arModules.some(function(m) { return ['ar_dashboard','ar_directory','ar_upload'].includes(m); });
var arLink = arModules.includes('ar_dashboard') ? '/ar' : arModules.includes('ar_directory') ? '/ar/directory' : '/ar/upload';
%>
<%- include('layout', { body: `<div class="space-y-6">
    <!-- Header Section -->
    <div>
        <h1 class="text-3xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">KOSCA ERP</h1>
        <p class="mt-2 text-base text-gray-500 dark:text-gray-400 max-w-2xl">Welcome to your centralized internal portal. Select a module
            below to get started with your daily operations.</p>
    </div>

    <!-- Modules Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-8">

        <!-- AR Module Card -->
        ${hasAR
