<%- include('../partials/layout_top') %>

<%- include('../partials/subnav') %>

    <main id="main-content" class="max-w-7xl mx-auto py-4 sm:py-6 px-4 lg:px-8">
        <h1 class="sr-only">Customer Assignments</h1>
        <div x-data="assignmentForm()" class="space-y-6">

            <!-- Assignment Form -->
            <div class="bg-white dark:bg-[var(--surface-primary)] rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
                <div class="px-4 md:px-5 py-3.5 border-b border-gray-100 dark:border-gray-700 flex items-center rounded-t-xl overflow-hidden">
                    <div class="flex items-center gap-2.5">
                        <div class="p-1.5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-lg border border-indigo-100 dark:border-indigo-800">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">New Assignment</h2>
                    </div>
                </div>
                <div class="p-6">
                <form action="/ar/assignments" method="POST" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label for="userId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Collection Officer</label>
                            <select name="userId" id="userId" required
                                class="block w-full rounded-xl border-0 py-2.5 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-700 focus:ring-2 focus:ring-indigo-500 sm:text-sm font-medium bg-white dark:bg-[var(--input-bg)]">
                                <option value="">Select a user...</option>
                                <% officers.forEach(function(o) { %>
                                    <option value="<%= o.id %>"><%= o.name %> (<%= o.email %>)</option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">Customer Codes</label>
                            <div class="relative">
                                <input type="text" x-model="searchTerm" @input="filterCodes()"
                                    @focus="showDropdown = true" @click.away="showDropdown = false"
                                    placeholder="Search customer code or name..."
                                    class="block w-full rounded-xl border-0 py-2.5 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-700 focus:ring-2 focus:ring-indigo-500 sm:text-sm bg-white dark:bg-[var(--input-bg)] placeholder:text-gray-400 dark:placeholder:text-gray-500">
                                <div x-show="showDropdown && filteredCodes.length > 0" x-transition
                                    class="absolute z-20 mt-1 w-full bg-white dark:bg-[var(--dropdown-bg)] rounded-xl shadow-xl dark:shadow-[var(--dropdown-shadow)] border border-gray-200 dark:border-[var(--dropdown-border)] max-h-48 overflow-y-auto"
                                    style="display: none;">
                                    <template x-for="c in filteredCodes" :key="c.code">
                                        <button type="button" @click="addCode(c)"
                                            class="w-full px-3 py-2 text-left text-sm hover:bg-indigo-50 dark:hover:bg-[var(--dropdown-hover)] flex justify-between items-center transition-colors">
                                            <span><span class="font-mono font-bold text-gray-700 dark:text-gray-300" x-text="c.code"></span> <span class="text-gray-400 dark:text-gray-500" x-text="'— ' + c.name"></span></span>
                                        </button>
                                    </template>
                                </div>
                            </div>
                            <div class="flex flex-wrap gap-2 mt-2" x-show="selectedCodes.length > 0">
                                <template x-for="code in selectedCodes" :key="code">
                                    <span class="inline-flex items-center gap-1 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 px-2.5 py-1 text-xs font-bold text-indigo-700 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-700 shadow-sm">
                                        <input type="hidden" name="customerCodes" :value="code">
                                        <span x-text="code"></span>
                                        <button type="button" @click="removeCode(code)" class="text-indigo-400 dark:text-indigo-500 hover:text-red-500 transition-colors ml-0.5">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                    </span>
                                </template>
                            </div>
                        </div>
                    </div>
                    <div class="flex justify-end">
                        <button type="submit" :disabled="selectedCodes.length === 0"
                            class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white shadow-md hover:bg-indigo-500 transition-all disabled:opacity-40 disabled:cursor-not-allowed">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                            </svg>
                            Assign Selected
                        </button>
                    </div>
                </form>
                </div>
            </div>

            <!-- Current Assignments -->
            <div class="bg-white dark:bg-[var(--surface-primary)] rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
                <div class="px-4 md:px-5 py-3.5 border-b border-gray-100 dark:border-gray-700 flex items-center">
                    <div class="flex items-center gap-2.5">
                        <div class="p-1.5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-lg border border-indigo-100 dark:border-indigo-800">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Current Assignments</h2>
                    </div>
                </div>
                <% if (Object.keys(groupedByUser).length === 0) { %>
                    <div class="py-12 text-center">
                        <div class="p-3 bg-gray-50 dark:bg-gray-800 rounded-full inline-block mb-3">
                            <svg class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                            </svg>
                        </div>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">No assignments yet.</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Use the form above to assign customer codes to Collection Officers.</p>
                    </div>
                <% } else { %>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        <% Object.keys(groupedByUser).forEach(function(uid) { var group = groupedByUser[uid]; %>
                            <div class="px-6 py-4">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="h-8 w-8 rounded-full bg-gradient-to-br from-indigo-500 to-indigo-700 flex items-center justify-center text-white font-bold text-xs shadow-sm">
                                        <%= group.userName.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <span class="font-bold text-gray-900 dark:text-gray-100 text-sm"><%= group.userName %></span>
                                        <span class="ml-2 inline-flex items-center rounded-md bg-gray-100 dark:bg-gray-800 px-2 py-0.5 text-[10px] font-bold text-gray-500 dark:text-gray-400"><%= group.assignments.length %> assigned</span>
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2 ml-11">
                                    <% group.assignments.forEach(function(a) { %>
                                        <div class="inline-flex items-center gap-2 rounded-lg bg-gray-50 dark:bg-gray-800 px-3 py-1.5 text-xs border border-gray-200 dark:border-gray-700 shadow-sm group/chip hover:border-red-200 dark:hover:border-red-800 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                                            <div>
                                                <span class="font-mono font-bold text-gray-700 dark:text-gray-300"><%= a.customerCode %></span>
                                                <span class="text-gray-400 dark:text-gray-500 ml-1">— <%= a.customerName %></span>
                                            </div>
                                            <form action="/ar/assignments/<%= a.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Remove this assignment?');">
                                                <button type="submit" class="text-gray-300 dark:text-gray-600 hover:text-red-500 transition-colors opacity-0 group-hover/chip:opacity-100" title="Remove">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script id="codesData" type="application/json"><%- JSON.stringify(customerCodes.map(function(c){return{code:c.customerCode,name:c.customerName||''}})) %></script>
    <script>
        function assignmentForm() {
            const allCodes = JSON.parse(document.getElementById('codesData').textContent);
            return {
                searchTerm: '',
                showDropdown: false,
                selectedCodes: [],
                allCodes: allCodes,
                filteredCodes: allCodes.slice(0, 50),
                filterCodes() {
                    const term = this.searchTerm.toLowerCase();
                    this.filteredCodes = this.allCodes
                        .filter(c => !this.selectedCodes.includes(c.code))
                        .filter(c => !term || c.code.toLowerCase().includes(term) || c.name.toLowerCase().includes(term))
                        .slice(0, 50);
                    this.showDropdown = true;
                },
                addCode(c) {
                    if (!this.selectedCodes.includes(c.code)) this.selectedCodes.push(c.code);
                    this.searchTerm = '';
                    this.filterCodes();
                },
                removeCode(code) {
                    this.selectedCodes = this.selectedCodes.filter(c => c !== code);
                    this.filterCodes();
                }
            };
        }
    </script>

<%- include('../partials/layout_bottom') %>
