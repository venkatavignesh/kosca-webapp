<%- include('../partials/layout_top') %>
<%- include('../partials/subnav') %>

<div style="background:var(--page-bg);min-height:calc(100vh - 48px)">
<main id="main-content" class="max-w-7xl mx-auto py-4 sm:py-6 px-4 lg:px-8">
    <h1 class="sr-only">Customer Invoices</h1>
    <div class="space-y-4">

        <!-- Header -->
        <div class="flex items-center gap-2.5">
            <button type="button" onclick="history.back()" class="p-1.5 rounded-lg hover:bg-white/60 dark:hover:bg-gray-700/60 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            <div class="flex-1 min-w-0 flex items-center gap-2.5 flex-wrap">
                <span class="text-sm font-bold text-gray-900 dark:text-gray-100 truncate"><%= customerName %></span>
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono"><%= customerCode %></span>
                <% if (currentGroup) { %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold bg-violet-50 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 border border-violet-200 dark:border-violet-700"><%= currentGroup %></span>
                <% } %>
                <% if (psrName) { %>
                <span class="inline-flex items-center rounded-md px-1.5 py-px text-[10px] font-medium leading-tight bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-700"><%= psrName %></span>
                <% } %>
            </div>

            <% if (isAdmin) { %>
            <div x-data="{ grp: '', saving: false }" class="flex-shrink-0 flex items-center gap-1.5">
                <select x-model="grp" class="rounded-lg border-0 py-1.5 pl-3 pr-7 text-xs text-gray-700 dark:text-gray-300 ring-1 ring-inset ring-gray-200 dark:ring-gray-700 focus:ring-2 focus:ring-indigo-400 bg-white dark:bg-[var(--input-bg)] appearance-none">
                    <option value=""><% if (currentGroup) { %>Move to group&hellip;<% } else { %>Assign to group&hellip;<% } %></option>
                    <% allGroups.forEach(function(g) { %>
                    <option value="<%= g %>"><%= g %></option>
                    <% }); %>
                </select>
                <button type="button" :disabled="!grp || saving"
                    data-code="<%= encodeURIComponent(customerCode) %>"
                    @click="const _c=$el.dataset.code,_u='/admin/groups/'+encodeURIComponent(grp)+'/add-member',_b='customerCode='+_c;saving=true;fetch(_u,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:_b}).then(async r=>{if(r.ok){location.reload();}else if(r.status===409){const cur=await r.text();saving=false;if(confirm('Currently in '+cur+'. Move to selected group?')){saving=true;fetch(_u,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:_b+'&force=true'}).then(r2=>{if(r2.ok)location.reload();else saving=false;});}}else{saving=false;}})"
                    class="px-2.5 py-1.5 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 text-xs font-semibold hover:bg-indigo-100 dark:hover:bg-indigo-900/50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    <span x-text="saving ? '…' : 'Assign'"></span>
                </button>
                <% if (currentGroup) { %>
                <button type="button"
                    data-code="<%= encodeURIComponent(customerCode) %>"
                    @click="if(confirm('Remove from group?')) fetch('/admin/groups/member/'+$el.dataset.code+'/remove',{method:'POST'}).then(r=>{if(r.ok) location.reload()})"
                    class="p-1.5 rounded-lg text-gray-300 dark:text-gray-600 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Remove from group">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
                <% } %>
            </div>
            <% } %>
        </div>

        <!-- Invoice card -->
        <div class="bg-white dark:bg-[var(--surface-primary)] rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
            <%
                const _fmtSummary = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
                const _activeInv = invoices.filter(i => i.status === 'ACTIVE');
                const _totalOut  = _activeInv.reduce((s, i) => s + (i.balanceAmount || 0), 0);
                const _maxAge    = _activeInv.reduce((m, i) => Math.max(m, i.agingDays || 0), 0);
                const _ageCls    = _maxAge > 90 ? 'text-red-600' : _maxAge > 60 ? 'text-orange-500' : _maxAge > 30 ? 'text-amber-500' : 'text-gray-900 dark:text-gray-100';
            %>
            <div class="px-5 py-3 bg-indigo-50/40 dark:bg-indigo-900/20 border-b border-indigo-100 dark:border-indigo-800 flex items-center gap-8">
                <div>
                    <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-500 tracking-wider">Outstanding</div>
                    <div class="text-base font-bold text-gray-900 dark:text-gray-100 mt-0.5"><%= _fmtSummary.format(_totalOut) %></div>
                </div>
                <div>
                    <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-500 tracking-wider">Active Invoices</div>
                    <div class="text-base font-bold text-gray-900 dark:text-gray-100 mt-0.5"><%= _activeInv.length %></div>
                </div>
                <% if (_maxAge > 0) { %>
                <div>
                    <div class="text-[10px] uppercase font-semibold text-gray-400 dark:text-gray-500 tracking-wider">Max Aging</div>
                    <div class="text-base font-bold mt-0.5 <%= _ageCls %>"><%= _maxAge %>d</div>
                </div>
                <% } %>
            </div>
            <%- include('../partials/invoice_details') %>
        </div>

    </div>
</main>
</div>

<%- include('../partials/layout_bottom') %>
