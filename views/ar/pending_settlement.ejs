<%- include('../layout', { body: `<div class="space-y-5 w-full">
    <h1 class="sr-only">Pending Settlement</h1>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col">

        <!-- Card Header -->
        <div class="px-3 sm:px-5 py-2.5 border-b border-gray-100 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5">
                <div class="p-1.5 bg-indigo-50 text-indigo-600 rounded-lg border border-indigo-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">Pending Settlement</h2>
                </div>
            </div>
            <span class="text-xs text-gray-500 font-medium">${total.toLocaleString('en-IN')} customers</span>
        </div>

        <!-- Search & Controls -->
        <form method="GET" action="/ar/pending-settlement" class="px-3 sm:px-5 py-2.5 flex flex-col sm:flex-row items-center gap-2 border-b border-gray-100 bg-gray-50/50">
            <div class="relative flex-1 w-full sm:max-w-xs">
                <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text" name="search" value="${search || ''}"
                    placeholder="Search customer code, name or doc no…"
                    class="w-full pl-8 pr-3 py-1.5 text-xs border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 bg-white"
                    oninput="clearTimeout(this._t);this._t=setTimeout(()=>{this.form.querySelector('[name=page]').value=1;this.form.submit()},500)">
            </div>
            <div class="flex items-center gap-2 ml-auto">
                <label class="text-xs text-gray-500">Show</label>
                <select name="limit" onchange="this.form.querySelector('[name=page]').value=1;this.form.submit()"
                    class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-300 bg-white">
                    ${[10, 25, 50, 100].map(function(n){ return '<option value="' + n + '"' + (limit == n ? ' selected' : '') + '>' + n + '</option>'; }).join('')}
                </select>
                ${search ? '<a href="/ar/pending-settlement" class="text-xs text-indigo-600 hover:underline">Clear</a>' : ''}
            </div>
            <input type="hidden" name="page" value="1">
        </form>

        <!-- Table -->
        <div class="overflow-x-auto">
            ${groups.length === 0
                ? '<div class="py-12 text-center text-gray-400 text-sm">No pending settlement records found' + (search ? ' for &ldquo;' + search + '&rdquo;' : '') + '.</div>'
                : (() => {
                    var rows = groups.map(function(g, idx) {
                        var rowBase = idx % 2 === 0 ? 'bg-white' : 'bg-gray-100';
                        var totalStr = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 2 }).format(g.totalAmount);

                        var childRows = g.records.map(function(r) {
                            var dateStr = '';
                            if (r.documentDate) {
                                var d = new Date(r.documentDate);
                                var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                                dateStr = String(d.getDate()).padStart(2,'0') + '-' + months[d.getMonth()] + '-' + d.getFullYear();
                            }
                            var amtStr = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 2 }).format(r.amount);
                            var tc = (r.type || '').toUpperCase();
                            var badgeColor = tc === 'CR'  ? 'bg-green-50 text-green-700 border-green-200'
                                           : tc === 'SRN' ? 'bg-amber-50 text-amber-700 border-amber-200'
                                           : tc === 'ADV' ? 'bg-blue-50 text-blue-700 border-blue-200'
                                           : 'bg-gray-50 text-gray-600 border-gray-200';
                            var typeLabel = tc === 'CR'  ? 'Credit Note'
                                          : tc === 'SRN' ? 'Sales Return'
                                          : tc === 'ADV' ? 'Advance'
                                          : r.type || '—';
                            var typeBadge = r.type
                                ? '<span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold ' + badgeColor + '">' + typeLabel + '</span>'
                                : '—';
                            return '<tr class="border-t border-gray-100">'
                                + '<td class="py-2 px-4 text-xs text-gray-500 whitespace-nowrap text-center">' + (dateStr || '—') + '</td>'
                                + '<td class="py-2 px-4 text-xs font-mono text-gray-700 whitespace-nowrap text-center">' + (r.documentNo || '—') + '</td>'
                                + '<td class="py-2 px-4 text-center">' + typeBadge + '</td>'
                                + '<td class="py-2 px-4 text-center text-xs font-semibold text-gray-800 tabular-nums whitespace-nowrap">' + amtStr + '</td>'
                                + '</tr>';
                        }).join('');

                        return '<tbody x-data="{ open: false }" class="border-b border-gray-100">'
                            + '<tr @click="open = !open" class="cursor-pointer select-none transition-colors" :class="open ? \'bg-indigo-50/40 border-b-2 border-indigo-200\' : \'' + rowBase + ' hover:bg-indigo-50/20\'">'
                            // Chevron
                            + '<td class="w-8 px-3 py-2.5">'
                            +   '<div class="flex items-center justify-center text-gray-400" :class="open ? \'text-indigo-500\' : \'\'">'
                            +     '<svg class="w-3.5 h-3.5 transition-transform duration-200" :class="open ? \'rotate-90\' : \'\'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>'
                            +   '</div>'
                            + '</td>'
                            // Code
                            + '<td class="px-3 py-2.5 whitespace-nowrap"><span class="text-xs font-mono text-gray-400">' + g.customerCode + '</span></td>'
                            // Name
                            + '<td class="px-3 py-2.5"><span class="text-sm font-semibold text-gray-900">' + (g.customerName || '—') + '</span></td>'
                            // Docs badge
                            + '<td class="px-3 py-2.5 text-center whitespace-nowrap"><span class="inline-flex items-center rounded-full bg-indigo-50 border border-indigo-200 px-2 py-0.5 text-[10px] font-semibold text-indigo-600">' + g.records.length + ' doc' + (g.records.length > 1 ? 's' : '') + '</span></td>'
                            // Total
                            + '<td class="px-3 py-2.5 text-right whitespace-nowrap"><span class="text-sm font-bold text-gray-900">' + totalStr + '</span></td>'
                            + '</tr>'
                            // Expanded panel
                            + '<tr x-show="open" x-cloak x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="border-b-2 border-indigo-100">'
                            +   '<td colspan="5" class="p-0 px-1 sm:px-5 pb-3 pt-1 bg-indigo-50/20">'
                            +     '<div class="border-l-4 border-indigo-300 rounded-b-lg overflow-hidden bg-white shadow-sm">'
                            +       '<table class="w-full text-xs"><colgroup><col style="width:15%"><col style="width:35%"><col style="width:25%"><col style="width:25%"></colgroup>'
                            +       '<thead><tr class="bg-gray-50 border-b border-gray-100">'
                            +         '<th class="py-2 px-4 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Doc Date</th>'
                            +         '<th class="py-2 px-4 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Document No</th>'
                            +         '<th class="py-2 px-4 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Type</th>'
                            +         '<th class="py-2 px-4 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Amount</th>'
                            +       '</tr></thead>'
                            +       '<tbody>' + childRows + '</tbody>'
                            +       '</table>'
                            +     '</div>'
                            +   '</td>'
                            + '</tr>'
                            + '</tbody>';
                    });
                    return '<table class="w-full border-collapse text-sm table-fixed"><colgroup><col style="width:3%"><col style="width:11%"><col style="width:55%"><col style="width:13%"><col style="width:18%"></colgroup>'
                        + '<thead><tr class="border-b border-gray-200 bg-gray-50/80">'
                        + '<th class="w-8 px-3 py-2"></th>'
                        + '<th class="px-3 py-2 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Code</th>'
                        + '<th class="px-3 py-2 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Customer</th>'
                        + '<th class="px-3 py-2 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Docs</th>'
                        + '<th class="px-3 py-2 text-right text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Total</th>'
                        + '</tr></thead>'
                        + rows.join('')
                        + '</table>';
                })()
            }
        </div>

        <!-- Pagination Footer -->
        ${totalPages > 1 ? (() => {
            var sp = search ? '&search=' + encodeURIComponent(search) : '';
            var base = '/ar/pending-settlement?limit=' + limit + sp;
            var dStart = Math.max(1, Math.min(page - 2, totalPages - 4));
            var dEnd   = Math.min(totalPages, dStart + 4);
            var pageButtons = '';
            for (var p = dStart; p <= dEnd; p++) {
                pageButtons += p === page
                    ? '<span class="px-3 py-1.5 rounded-lg text-sm font-medium border bg-indigo-600 border-indigo-600 text-white">' + p + '</span>'
                    : '<a href="' + base + '&page=' + p + '" class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors">' + p + '</a>';
            }
            return '<div class="px-4 py-3 border-t border-gray-100 flex flex-col items-center gap-2">'
                + '<p class="text-sm text-gray-500 whitespace-nowrap">Page <span class="font-semibold text-gray-800">' + page + '</span> of <span class="font-semibold text-gray-800">' + totalPages + '</span></p>'
                + '<div class="flex items-center gap-1">'
                + (page === 1
                    ? '<span class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 opacity-40 cursor-not-allowed">Previous</span>'
                    : '<a href="' + base + '&page=' + (page - 1) + '" class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors">Previous</a>')
                + pageButtons
                + (page === totalPages
                    ? '<span class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 opacity-40 cursor-not-allowed">Next</span>'
                    : '<a href="' + base + '&page=' + (page + 1) + '" class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors">Next</a>')
                + '</div></div>';
        })() : ''}

    </div>
</div>`, pageTitle: 'Pending Settlement', currentPath: '/ar/pending-settlement' }) %>
