<%- include('../layout', { body: `<div class="space-y-5 w-full">
    <h1 class="sr-only">AR Customer Directory</h1>

    <!-- Site badges -->
    ${selectedSites.length ? '<div class="flex flex-wrap gap-2 mb-3">' + selectedSites.map(function(s){ return '<span class="inline-flex items-center gap-1 rounded-full bg-violet-50 border border-violet-200 px-2.5 py-0.5 text-xs font-semibold text-violet-700">' + s + '</span>'; }).join('') + '</div>' : ''}

    <!-- Data Table Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col" x-data="{ catTab: '${keyOnly ? 'key' : subOnly ? 'sub' : 'nonkey'}' }">


        <!-- Card Header -->
        <div class="px-3 sm:px-5 py-2.5 border-b border-gray-100 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5">
                <div class="p-1.5 bg-indigo-50 text-indigo-600 rounded-lg border border-indigo-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h2 class="text-sm font-semibold text-gray-900">Customer Accounts</h2>
            </div>
            <button hx-get="/ar/invoices" hx-target="#table-data"
                hx-include="[name='search'], [name='limit'], [name='site'], [name='bucket'], [name='sort'], [name='psr'], [name='group'], [name='psr_badge'], [name='ps_only']"
                class="inline-flex items-center gap-1.5 rounded-lg bg-white px-2.5 py-1.5 text-xs font-medium text-gray-600 border border-gray-200 hover:bg-gray-50 transition-colors">
                <svg class="h-3.5 w-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Refresh
            </button>
        </div>

        <!-- Search / Filter Controls -->
        <div class="px-3 sm:px-5 py-2.5 flex flex-col sm:flex-row justify-between items-center gap-2 border-b border-gray-100 bg-gray-50/50">
            <div class="flex flex-wrap items-center gap-1.5 w-full sm:w-auto">
                <!-- Search -->
                <div class="relative w-full sm:w-72">
                    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                        <svg class="h-3.5 w-3.5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <input type="text" name="search" id="search-input"
                        hx-get="/ar/invoices"
                        hx-trigger="keyup changed delay:500ms, search"
                        hx-target="#table-data"
                        hx-include="[name='limit'], [name='site'], [name='bucket'], [name='sort'], [name='psr'], [name='group'], [name='psr_badge'], [name='ps_only']"
                        class="block w-full rounded-lg border-0 py-2 pl-9 pr-3 text-xs text-gray-900 ring-1 ring-inset ring-gray-200 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 bg-white"
                        placeholder="Search customer or invoice...">
                </div>

                <!-- Location filter dropdown -->
                <div class="relative"
                    x-data="{ open: false, siteCount: ${selectedSites.length} }"
                    @htmx:after-swap.window="siteCount = document.querySelectorAll('input[name=site]:checked').length">
                    <button type="button" @click="open = !open"
                        class="inline-flex items-center gap-1.5 rounded-lg border-0 py-2 pl-2.5 pr-2 text-xs text-gray-700 ring-1 ring-inset ring-gray-200 bg-white hover:bg-gray-50 focus:ring-2 focus:ring-indigo-500 transition-colors font-medium">
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Location
                        <span x-show="siteCount > 0" x-text="siteCount" class="ml-0.5 inline-flex items-center justify-center w-4 h-4 rounded-full bg-indigo-600 text-white text-[10px] font-bold"></span>
                        <svg class="w-3 h-3 text-gray-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="open" @click.outside="open = false" x-cloak
                        class="absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 py-1.5 min-w-[180px]">
                        ${allSiteNames.map(function(s) {
                            return '<label class="flex items-center gap-2.5 px-3.5 py-2 cursor-pointer hover:bg-gray-50 select-none">'
                                + '<input type="checkbox" name="site" value="' + s + '"'
                                + (selectedSites.includes(s) ? ' checked' : '')
                                + ' hx-get="/ar/invoices"'
                                + ' hx-trigger="change" hx-target="#table-data"'
                                + ' hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'], [name=\'group\'],  [name=\'psr_badge\'], [name=\'ps_only\']"'
                                + ' @change="siteCount = document.querySelectorAll(\'input[name=site]:checked\').length; var ns=Array.from(document.querySelectorAll(\'input[name=site]:checked\')).map(function(e){return e.value;}); if(ns.length>0){document.querySelectorAll(\'input[name=psr]:checked\').forEach(function(e){var ps=JSON.parse(e.dataset.sites||\'[]\');if(!ps.some(function(s){return ns.includes(s);})){e.checked=false;}});} window.dispatchEvent(new CustomEvent(\'sites-changed\',{detail:ns}));"'
                                + ' class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer">'
                                + '<span class="text-xs text-gray-700">' + s + '</span>'
                                + '</label>';
                        }).join('')}
                        ${selectedSites.length ? '<div class="border-t border-gray-100 mt-1 pt-1 px-3.5 pb-1"><button type="button" hx-get="/ar/invoices" hx-target="#table-data" hx-include="[name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'], [name=\'group\'],  [name=\'psr_badge\'], [name=\'ps_only\']" @click="document.querySelectorAll(\'[name=\\\'site\\\']\').forEach(function(el){el.checked=false;}); siteCount=0; window.dispatchEvent(new Event(\'sites-changed\')); open=false" class="text-xs text-red-500 hover:text-red-700 font-medium py-0.5">Clear all</button></div>' : ''}
                    </div>
                </div>

                <!-- Bucket filter dropdown -->
                <div class="relative"
                    x-data="{ open: false, bucketCount: ${bucket ? (Array.isArray(bucket) ? bucket.length : 1) : 0} }"
                    @htmx:after-swap.window="bucketCount = document.querySelectorAll('input[name=bucket]:checked').length">
                    <button type="button" @click="open = !open"
                        class="inline-flex items-center gap-1.5 rounded-lg border-0 py-2 pl-2.5 pr-2 text-xs text-gray-700 ring-1 ring-inset ring-gray-200 bg-white hover:bg-gray-50 focus:ring-2 focus:ring-indigo-500 transition-colors font-medium">
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/></svg>
                        Aging
                        <span x-show="bucketCount > 0" x-text="bucketCount" class="ml-0.5 inline-flex items-center justify-center w-4 h-4 rounded-full bg-indigo-600 text-white text-[10px] font-bold"></span>
                        <svg class="w-3 h-3 text-gray-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="open" @click.outside="open = false" x-cloak
                        class="absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 py-1.5 min-w-[180px]">
                        ${[['0_30','0–30 Days'],['31_60','31–60 Days'],['61_90','61–90 Days'],['91_120','91–120 Days'],['121_150','121–150 Days'],['151_180','151–180 Days'],['over_180','Over 180 Days']].map(function(opt) {
                            var checked = Array.isArray(bucket) ? bucket.includes(opt[0]) : bucket === opt[0];
                            return '<label class="flex items-center gap-2.5 px-3.5 py-2 cursor-pointer hover:bg-gray-50 select-none">'
                                + '<input type="checkbox" name="bucket" value="' + opt[0] + '"'
                                + (checked ? ' checked' : '')
                                + ' hx-get="/ar/invoices"'
                                + ' hx-trigger="change" hx-target="#table-data"'
                                + ' hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'], [name=\'group\'],  [name=\'psr_badge\'], [name=\'ps_only\']"'
                                + ' @change="bucketCount = document.querySelectorAll(\'input[name=bucket]:checked\').length"'
                                + ' class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer">'
                                + '<span class="text-xs text-gray-700">' + opt[1] + '</span>'
                                + '</label>';
                        }).join('')}
                    </div>
                </div>

                <!-- PSR filter dropdown -->
                <div id="psr-filter" class="relative"
                    x-data="{ open: false, activeSites: ${JSON.stringify(selectedSites).replace(/"/g, '&quot;')}, psrCount: ${selectedPsrs.length} }"
                    @sites-changed.window="activeSites = Array.from(document.querySelectorAll('input[name=site]:checked')).map(function(el){ return el.value; })">
                    <button type="button" @click="open = !open"
                        class="inline-flex items-center gap-1.5 rounded-lg border-0 py-2 pl-2.5 pr-2 text-xs text-gray-700 ring-1 ring-inset ring-gray-200 bg-white hover:bg-gray-50 focus:ring-2 focus:ring-indigo-500 transition-colors font-medium">
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        BDE / Trainers
                        <span x-show="psrCount > 0" x-text="psrCount" class="ml-0.5 inline-flex items-center justify-center w-4 h-4 rounded-full bg-indigo-600 text-white text-[10px] font-bold"></span>
                        <svg class="w-3 h-3 text-gray-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="open" @click.outside="open = false" x-cloak
                        class="absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 py-1.5 min-w-[200px] max-h-64 overflow-y-auto">
                        ${allPsrData.length === 0 ? '<div class="px-3.5 py-3 text-xs text-gray-400 italic">No BDEs available</div>' : ''}
                        ${allPsrData.map(function(p) {
                            var sitesJson = JSON.stringify(p.sites).replace(/"/g, '&quot;');
                            return '<label x-show="activeSites.length === 0 || ' + sitesJson + '.some(function(s){ return activeSites.includes(s); })" class="flex items-center gap-2.5 px-3.5 py-2 cursor-pointer hover:bg-gray-50 select-none">'
                                + '<input type="checkbox" name="psr" value="' + p.psrName.replace(/"/g, '&quot;') + '"'
                                + ' data-sites="' + JSON.stringify(p.sites).replace(/"/g, '&quot;') + '"'
                                + (selectedPsrs.includes(p.psrName) ? ' checked' : '')
                                + ' hx-get="/ar/invoices"'
                                + ' hx-trigger="change" hx-target="#table-data"'
                                + ' hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'], [name=\'group\'], [name=\'ps_only\']"'
                                + ' @change="psrCount = document.querySelectorAll(\'input[name=psr]:checked\').length"'
                                + ' class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer">'
                                + '<span class="text-xs text-gray-700">' + p.psrName.replace(/</g, '&lt;') + '</span>'
                                + '</label>';
                        }).join('')}
                        ${selectedPsrs.length ? '<div class="border-t border-gray-100 mt-1 pt-1 px-3.5 pb-1"><button type="button" hx-get="/ar/invoices" hx-target="#table-data" hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'group\'], [name=\'ps_only\']" @click="document.querySelectorAll(\'[name=\\\'psr\\\']\').forEach(function(el){el.checked=false;}); psrCount=0; open=false" class="text-xs text-red-500 hover:text-red-700 font-medium py-0.5">Clear all</button></div>' : ''}
                    </div>
                </div>

                <!-- Group filter dropdown -->
                <div id="group-filter" class="relative"
                    x-data="{ open: false, grpCount: ${selectedGroup ? 1 : 0}, activeSites: ${JSON.stringify(selectedSites).replace(/"/g, '&quot;')} }"
                    @sites-changed.window="activeSites = Array.from(document.querySelectorAll('input[name=site]:checked')).map(function(el){ return el.value; })">
                    <button type="button" @click="open = !open"
                        class="inline-flex items-center gap-1.5 rounded-lg border-0 py-2 pl-2.5 pr-2 text-xs text-gray-700 ring-1 ring-inset ring-gray-200 bg-white hover:bg-gray-50 focus:ring-2 focus:ring-indigo-500 transition-colors font-medium">
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                        Group
                        <span x-show="grpCount > 0" x-text="grpCount" class="ml-0.5 inline-flex items-center justify-center w-4 h-4 rounded-full bg-indigo-600 text-white text-[10px] font-bold"></span>
                        <svg class="w-3 h-3 text-gray-400 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="open" @click.outside="open = false" x-cloak
                        class="absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-20 py-1.5 min-w-[200px] max-h-64 overflow-y-auto">
                        ${allGroupData.length === 0 ? '<div class="px-3.5 py-3 text-xs text-gray-400 italic">No groups available</div>' : ''}
                        ${allGroupData.map(function(g) {
                            var safeG = g.groupName.replace(/"/g, '&quot;');
                            var dispG = g.groupName.replace(/</g, '&lt;');
                            var sitesJson = JSON.stringify(g.sites).replace(/"/g, '&quot;');
                            return '<label x-show="activeSites.length === 0 || ' + sitesJson + '.some(function(s){ return activeSites.includes(s); })" class="flex items-center gap-2.5 px-3.5 py-2 cursor-pointer hover:bg-gray-50 select-none">'
                                + '<input type="checkbox" name="group" value="' + safeG + '"'
                                + ' data-sites="' + sitesJson + '"'
                                + (selectedGroup === g.groupName ? ' checked' : '')
                                + ' hx-get="/ar/invoices"'
                                + ' hx-trigger="change" hx-target="#table-data"'
                                + ' hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'], [name=\'group\'],  [name=\'psr_badge\'], [name=\'ps_only\']"'
                                + ' @change="grpCount = document.querySelectorAll(\'input[name=group]:checked\').length"'
                                + ' class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer">'
                                + '<span class="text-xs text-gray-700">' + dispG + '</span>'
                                + '</label>';
                        }).join('')}
                        ${selectedGroup ? '<div class="border-t border-gray-100 mt-1 pt-1 px-3.5 pb-1"><button type="button" hx-get="/ar/invoices" hx-target="#table-data" hx-include="[name=\'site\'], [name=\'search\'], [name=\'limit\'], [name=\'bucket\'], [name=\'sort\'], [name=\'psr\'],  [name=\'psr_badge\'], [name=\'ps_only\']" @click="document.querySelectorAll(\'[name=\\\'group\\\']\').forEach(function(el){el.checked=false;}); grpCount=0; open=false" class="text-xs text-red-500 hover:text-red-700 font-medium py-0.5">Clear all</button></div>' : ''}
                    </div>
                </div>
            </div>

            ${(function(){
                var canPS = locals.hasModule && locals.hasModule('ar_pending_settlement');
                if (!canPS) return '';
                return '<label x-data="{ps: ' + (psOnly ? 'true' : 'false') + '}"'
                    + ' :class="ps ? \'bg-amber-50 border-amber-300 text-amber-700\' : \'bg-white border-gray-200 text-gray-600 hover:bg-amber-50/50 hover:text-amber-700\'"'
                    + ' class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium border cursor-pointer select-none whitespace-nowrap transition-colors"'
                    + ' title="Show only customers with pending settlement">'
                    + '<input type="checkbox" name="ps_only" value="1"'
                    + (psOnly ? ' checked' : '')
                    + ' x-model="ps"'
                    + ' hx-get="/ar/invoices" hx-trigger="change" hx-target="#table-data"'
                    + ' hx-include="[name=\'search\'],[name=\'limit\'],[name=\'site\'],[name=\'bucket\'],[name=\'sort\'],[name=\'psr\'],[name=\'group\'],[name=\'psr_badge\']"'
                    + ' class="w-3.5 h-3.5 rounded accent-amber-600 cursor-pointer">'
                    + 'Pending Settlement'
                    + '</label>';
            })()}

            <div class="flex items-center gap-1.5 text-xs text-gray-600 self-end sm:self-auto">
                <div class="relative">
                    <select name="sort"
                        hx-get="/ar/invoices"
                        hx-trigger="change" hx-target="#table-data"
                        hx-include="[name='search'], [name='site'], [name='bucket'], [name='limit'], [name='psr'], [name='group'], [name='psr_badge'], [name='ps_only']"
                        class="appearance-none rounded-lg border border-gray-200 py-1.5 pl-2.5 pr-7 text-xs text-gray-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 bg-white cursor-pointer font-medium">
                        <option value="balance_desc">Outstanding ↓</option>
                        <option value="balance_asc">Outstanding ↑</option>
                        <option value="aging_desc">Aging ↓</option>
                        <option value="aging_asc">Aging ↑</option>
                        <option value="name_asc">Name A→Z</option>
                        <option value="name_desc">Name Z→A</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2">
                        <svg class="h-3 w-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </div>
                </div>
                <div class="relative">
                    <select name="limit" id="limit"
                        hx-get="/ar/invoices"
                        hx-trigger="change" hx-target="#table-data"
                        hx-include="[name='search'], [name='site'], [name='bucket'], [name='sort'], [name='psr'], [name='group'], [name='psr_badge'], [name='ps_only']"
                        class="appearance-none rounded-lg border border-gray-200 py-1.5 pl-2.5 pr-7 text-xs text-gray-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 bg-white cursor-pointer font-medium">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2">
                        <svg class="h-3 w-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Sub-Tabs -->
        ${(function() {
            var isAdmin = user && user.role === 'ADMIN';
            var mods = (user && user.modules) || [];
            var canKey = isAdmin || mods.includes('ar_key_accounts');
            var canSub = isAdmin || mods.includes('ar_sub_distributors');
            if (!canKey && !canSub) return '';
            var siteQ = selectedSites.length ? selectedSites.map(function(s){ return 'site=' + encodeURIComponent(s); }).join('&') : '';
            var bQ = bucket ? (siteQ ? '&' : '') + 'bucket=' + bucket : '';
            var html = '<div class="flex justify-center gap-0 border-b border-gray-100 bg-gray-50/30">';
            if (canKey) html += '<button @click="catTab=\'key\'" hx-get="/ar/invoices?keyOnly=1' + (siteQ ? '&' + siteQ : '') + bQ + '" hx-target="#table-data" hx-include="[name=\'search\'],[name=\'limit\'],[name=\'bucket\'],[name=\'sort\'],[name=\'psr\'],[name=\'group\'], [name=\'psr_badge\'], [name=\'ps_only\']" :class="catTab===\'key\' ? \'border-b-2 border-indigo-500 text-indigo-600 font-semibold\' : \'border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300\'" class="px-4 py-2 text-xs whitespace-nowrap transition-colors">Key</button>';
            if (canSub) html += '<button @click="catTab=\'sub\'" hx-get="/ar/invoices?subOnly=1' + (siteQ ? '&' + siteQ : '') + bQ + '" hx-target="#table-data" hx-include="[name=\'search\'],[name=\'limit\'],[name=\'bucket\'],[name=\'sort\'],[name=\'psr\'],[name=\'group\'], [name=\'psr_badge\'], [name=\'ps_only\']" :class="catTab===\'sub\' ? \'border-b-2 border-indigo-500 text-indigo-600 font-semibold\' : \'border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300\'" class="px-4 py-2 text-xs whitespace-nowrap transition-colors">Sub D</button>';
            html += '<button @click="catTab=\'nonkey\'" hx-get="/ar/invoices?' + siteQ + bQ + '" hx-target="#table-data" hx-include="[name=\'search\'],[name=\'limit\'],[name=\'bucket\'],[name=\'sort\'],[name=\'psr\'],[name=\'group\'], [name=\'psr_badge\'], [name=\'ps_only\']" :class="catTab===\'nonkey\' ? \'border-b-2 border-indigo-500 text-indigo-600 font-semibold\' : \'border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300\'" class="px-4 py-2 text-xs whitespace-nowrap transition-colors">Non-Key</button>';
            html += '</div>';
            return html;
        })()}

        <!-- HTMX Target -->
        <div id="table-data" class="bg-transparent overflow-hidden rounded-b-2xl"
            hx-get="/ar/invoices?${keyOnly ? 'keyOnly=1' : subOnly ? 'subOnly=1' : ''}${bucket ? (keyOnly||subOnly ? '&' : '') + 'bucket=' + bucket : ''}"
