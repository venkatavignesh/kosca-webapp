<%- include('../partials/layout_top') %>

<%- include('../partials/subnav') %>

    <main id="main-content" class="max-w-7xl mx-auto py-4 sm:py-6 px-4 lg:px-8">
        <h1 class="sr-only">Site Assignments</h1>
        <div class="space-y-6">

            <!-- Table Card -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

                <!-- Card Header -->
                <div class="px-4 md:px-5 py-3.5 border-b border-gray-100 flex items-center">
                    <div class="flex items-center gap-2.5">
                        <div class="p-1.5 bg-indigo-50 text-indigo-600 rounded-lg border border-indigo-100">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900">Site Assignments</h2>
                    </div>
                </div>

                <!-- Search & Controls -->
                <div class="px-5 py-3.5 border-b border-gray-100 bg-gray-50/50 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <form method="GET" action="/admin/site-assignments" class="flex gap-2 w-full sm:w-auto">
                        <div class="relative flex-1 sm:w-72">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <input type="text" name="search" value="<%= search %>"
                                class="block w-full rounded-lg border-0 py-2 pl-10 pr-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-200 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 bg-white"
                                placeholder="Search customer or code...">
                            <input type="hidden" name="limit" value="<%= limit %>">
                        </div>
                        <button type="submit" class="inline-flex items-center rounded-lg bg-white px-3.5 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:bg-gray-50 transition-colors">Search</button>
                        <% if (search) { %>
                            <a href="/admin/site-assignments?limit=<%= limit %>" class="inline-flex items-center rounded-lg px-3 py-2 text-sm text-gray-500 hover:text-gray-700 border border-gray-200 bg-white hover:bg-gray-50 transition-colors">Clear</a>
                        <% } %>
                    </form>
                    <div class="flex items-center gap-2 self-end sm:self-auto">
                        <label class="text-xs font-medium text-gray-500">Show:</label>
                        <div class="relative">
                            <select onchange="window.location='/admin/site-assignments?limit='+this.value+'&search=<%= encodeURIComponent(search) %>'"
                                class="appearance-none rounded-lg border border-gray-200 py-2 pl-3 pr-8 text-sm text-gray-900 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 bg-white cursor-pointer font-medium">
                                <option value="10" <%= limit==10?'selected':'' %>>10 rows</option>
                                <option value="20" <%= limit==20?'selected':'' %>>20 rows</option>
                                <option value="50" <%= limit==50?'selected':'' %>>50 rows</option>
                                <option value="100" <%= limit==100?'selected':'' %>>100 rows</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2.5">
                                <svg class="h-3.5 w-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Count bar -->
                <div class="px-5 py-2 border-b border-gray-100 bg-gray-50/30 flex items-center justify-between">
                    <span class="text-xs text-gray-500"><span class="font-bold text-gray-800"><%= totalCount %></span> customer<%= totalCount !== 1 ? 's' : '' %><% if (search) { %> for "<%= search %>"<% } %></span>
                    <% if (totalCount > 0) { %><span class="text-xs text-gray-400">Showing <%= (page-1)*limit+1 %>–<%= Math.min(page*limit, totalCount) %></span><% } %>
                </div>

                <!-- Table -->
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-100">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="py-2.5 pl-5 pr-4 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Customer</th>
                                <th scope="col" class="px-4 py-2.5 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Current Site</th>
                                <th scope="col" class="px-4 py-2.5 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Move To</th>
                                <th scope="col" class="px-4 py-2.5"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (customers.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="py-12 text-center text-sm text-gray-400">No customers found.</td>
                                </tr>
                            <% } %>
                            <% customers.forEach(function(c) { %>
                                <tr class="hover:bg-gray-50/60 transition-colors">
                                    <td class="py-2.5 pl-5 pr-4">
                                        <div class="text-xs font-bold text-gray-900"><%= c.customerName || '—' %></div>
                                        <div class="text-[11px] font-mono text-gray-400 mt-0.5"><%= c.customerCode %></div>
                                    </td>
                                    <td class="px-4 py-2.5 text-center">
                                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold
                                            <%= c.currentSite === 'Unknown' ? 'bg-gray-100 text-gray-500' : 'bg-violet-50 text-violet-700 border border-violet-200' %>">
                                            <%= c.currentSite %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-2.5">
                                        <form method="POST" action="/admin/site-assignments/<%= encodeURIComponent(c.customerCode) %>/move" class="flex items-center gap-2">
                                            <div class="relative">
                                                <select name="siteName" required
                                                    class="appearance-none rounded-lg border border-gray-200 py-2 pl-3 pr-8 text-sm text-gray-900 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 bg-white cursor-pointer min-w-[160px]">
                                                    <option value="" disabled selected>Select site...</option>
                                                    <% siteNames.forEach(function(s) { %>
                                                        <option value="<%= s %>" <%= s === c.currentSite ? 'selected' : '' %>><%= s %></option>
                                                    <% }); %>
                                                </select>
                                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2.5">
                                                    <svg class="h-3.5 w-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                                </div>
                                            </div>
                                            <button type="submit" class="inline-flex items-center rounded-lg bg-indigo-600 px-3.5 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition-colors">Move</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                <div class="px-4 py-3 border-t border-gray-100 flex flex-col items-center gap-2">
                    <p class="text-sm text-gray-500 whitespace-nowrap">Page <span class="font-semibold text-gray-800"><%= page %></span> of <span class="font-semibold text-gray-800"><%= totalPages %></span></p>
                    <div class="flex items-center gap-1">
                        <a href="/admin/site-assignments?page=<%= Math.max(1, page - 1) %>&search=<%= encodeURIComponent(search) %>&limit=<%= limit %>"
                            class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors <%= page === 1 ? 'opacity-40 pointer-events-none' : '' %>">Previous</a>
                        <% var startPage = Math.max(1, page - 2);
                           var endPage = Math.min(totalPages, startPage + 4);
                           startPage = Math.max(1, endPage - 4);
                           for (var p = startPage; p <= endPage; p++) { %>
                            <a href="/admin/site-assignments?page=<%= p %>&search=<%= encodeURIComponent(search) %>&limit=<%= limit %>"
                                class="px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors <%= p === page ? 'bg-indigo-600 border-indigo-600 text-white' : 'border-gray-200 text-gray-600 hover:bg-gray-50' %>"><%= p %></a>
                        <% } %>
                        <a href="/admin/site-assignments?page=<%= Math.min(totalPages, page + 1) %>&search=<%= encodeURIComponent(search) %>&limit=<%= limit %>"
                            class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors <%= page === totalPages ? 'opacity-40 pointer-events-none' : '' %>">Next</a>
                    </div>
                </div>
                <% } %>

            </div>
        </div>
    </main>

<%- include('../partials/layout_bottom') %>
