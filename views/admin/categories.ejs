<%- include('../partials/layout_top') %>

<%- include('../partials/subnav') %>

    <main id="main-content" class="max-w-7xl mx-auto py-4 sm:py-6 px-4 lg:px-8">
        <h1 class="sr-only">Customer Categories</h1>
        <div class="space-y-6" x-data="{ tab: '<%= tab %>', search: '' }">

            <!-- Main card -->
            <div class="bg-white dark:bg-[var(--surface-primary)] rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
                <!-- Card Header -->
                <div class="px-4 md:px-5 py-3.5 border-b border-gray-100 dark:border-gray-700 flex items-center">
                    <div class="flex items-center gap-2.5">
                        <div class="p-1.5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-lg border border-indigo-100 dark:border-indigo-800">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Customer Categories</h2>
                    </div>
                </div>

                <!-- Tabs -->
                <div class="flex justify-center border-b border-gray-100 dark:border-gray-700 bg-gray-50/30 dark:bg-gray-800/30 px-2">
                    <button @click="tab='key'; search=''; history.replaceState(null,'','/admin/categories?tab=key')"
                        :class="tab==='key' ? 'border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 font-semibold' : 'border-b-2 border-transparent text-[#3d3878] dark:text-gray-400 hover:text-indigo-700 dark:hover:text-gray-300 hover:border-indigo-200'"
                        class="px-4 py-2 text-xs whitespace-nowrap transition-colors">
                        Key Accounts
                        <span class="ml-1 px-2 py-0.5 rounded-full text-[10px] font-semibold"
                              :class="tab==='key' ? 'bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400' : 'bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400'"><%= keyTotal %></span>
                    </button>
                    <button @click="tab='sub'; search=''; history.replaceState(null,'','/admin/categories?tab=sub')"
                        :class="tab==='sub' ? 'border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 font-semibold' : 'border-b-2 border-transparent text-[#3d3878] dark:text-gray-400 hover:text-indigo-700 dark:hover:text-gray-300 hover:border-indigo-200'"
                        class="px-4 py-2 text-xs whitespace-nowrap transition-colors">
                        Sub Distributors
                        <span class="ml-1 px-2 py-0.5 rounded-full text-[10px] font-semibold"
                              :class="tab==='sub' ? 'bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400' : 'bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400'"><%= subTotal %></span>
                    </button>
                </div>

                <!-- Key Accounts Tab -->
                <div x-show="tab==='key'" x-cloak>
                    <!-- Info banner -->
                    <div class="px-4 md:px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-indigo-50/50 dark:bg-indigo-900/20 flex items-start gap-3">
                        <svg class="w-4 h-4 text-indigo-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-xs text-indigo-600 dark:text-indigo-400">Auto-detected by customer name prefix. <span class="font-medium"><%= keyTotal %> customers</span> across <%= prefixes.length %> groups.</p>
                    </div>

                    <!-- Search -->
                    <div class="px-4 md:px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex items-center gap-3">
                        <div class="relative flex-1 max-w-sm">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <input type="text" placeholder="Search code or name..."
                                x-model="search"
                                class="block w-full rounded-lg border-0 py-2 pl-10 pr-4 text-xs text-gray-900 dark:text-[var(--input-text)] ring-1 ring-inset ring-gray-200 dark:ring-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 bg-white dark:bg-[var(--input-bg)]">
                        </div>
                        <span class="ml-auto text-xs text-gray-400 dark:text-gray-500 font-medium whitespace-nowrap"><%= keyTotal %> total</span>
                    </div>

                    <% if (keyAccounts.length === 0) { %>
                        <div class="py-12 text-center text-sm text-gray-400 dark:text-gray-500">No key accounts detected.</div>
                    <% } else { %>
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse text-sm">
                                <thead>
                                    <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50/80 dark:bg-gray-800/80">
                                        <th class="w-7 px-2 py-2"></th>
                                        <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Prefix</th>
                                        <th class="px-2 py-2 text-center text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Doors</th>
                                    </tr>
                                </thead>
                                <% prefixes.forEach(function(prefix) { var group = keyGroups[prefix] || []; if (group.length === 0) return; %>
                                <tbody x-data="{ open: false }">
                                    <tr class="border-b border-violet-200 dark:border-violet-800 cursor-pointer select-none transition-colors hover:bg-violet-100/60 dark:hover:bg-violet-900/40 bg-violet-50 dark:bg-violet-900/20" :class="open ? '!bg-violet-100/60 dark:!bg-violet-900/30 !border-b-2 !border-violet-300 dark:!border-violet-700' : ''" @click="open = !open">
                                        <td class="px-2 py-2 w-7">
                                            <div class="flex items-center justify-center text-violet-400 transition-colors" :class="open ? 'text-violet-600' : ''">
                                                <svg class="w-3 h-3 transition-transform duration-200" :class="open ? 'rotate-90' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                                            </div>
                                        </td>
                                        <td class="px-2 py-2"><span class="text-xs font-bold text-violet-900 dark:text-violet-300"><%= prefix %></span></td>
                                        <td class="px-2 py-2 text-center whitespace-nowrap"><span class="text-[11px] text-gray-500 dark:text-gray-400"><%= group.length %></span></td>
                                    </tr>
                                    <tr x-show="open" x-cloak class="border-b-2 border-violet-100 dark:border-violet-900">
                                        <td colspan="3" class="p-0 px-3 pb-3">
                                            <div class="border-l-3 border-violet-300 dark:border-violet-700 bg-slate-50/60 dark:bg-gray-800/60 rounded-b-lg overflow-hidden">
                                                <table class="w-full border-collapse text-sm">
                                                    <thead>
                                                        <tr class="border-b border-gray-200 dark:border-gray-700 bg-white/70 dark:bg-gray-800/70">
                                                            <th class="px-2 py-1.5 text-left text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Code</th>
                                                            <th class="px-2 py-1.5 text-left text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Customer</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% group.forEach(function(ka, idx) { %>
                                                        <tr class="<%= idx % 2 === 1 ? 'bg-gray-100 dark:bg-gray-800' : 'bg-white dark:bg-[var(--surface-primary)]' %> border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors"
                                                            x-show="!search || '<%= (ka.customerCode || '').toLowerCase() %>'.includes(search.toLowerCase()) || '<%= (ka.customerName || '').toLowerCase().replace(/'/g, "\\'") %>'.includes(search.toLowerCase())">
                                                            <td class="px-2 py-1.5 whitespace-nowrap"><span class="text-[11px] text-gray-400 dark:text-gray-500 font-mono"><%= ka.customerCode %></span></td>
                                                            <td class="px-2 py-1.5"><span class="text-xs font-semibold text-gray-900 dark:text-gray-100"><% if (ka.customerName) { %><%= ka.customerName %><% } else { %><span class="text-gray-300">—</span><% } %></span></td>
                                                        </tr>
                                                        <% }); %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                                <% }); %>
                            </table>
                        </div>
                    <% } %>
                </div>

                <!-- Sub Distributors Tab -->
                <div x-show="tab==='sub'" x-cloak>
                    <!-- Info banner -->
                    <div class="px-4 md:px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-indigo-50/50 dark:bg-indigo-900/20 flex items-start gap-3">
                        <svg class="w-4 h-4 text-indigo-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-xs text-indigo-600 dark:text-indigo-400"><%= subTotal %> fixed customer codes configured in the system.</p>
                    </div>

                    <!-- Search -->
                    <div class="px-4 md:px-5 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 flex items-center gap-3">
                        <div class="relative flex-1 max-w-sm">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <input type="text" placeholder="Search code or name..."
                                x-model="search"
                                class="block w-full rounded-lg border-0 py-2 pl-10 pr-4 text-xs text-gray-900 dark:text-[var(--input-text)] ring-1 ring-inset ring-gray-200 dark:ring-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 bg-white dark:bg-[var(--input-bg)]">
                        </div>
                        <span class="ml-auto text-xs text-gray-400 dark:text-gray-500 font-medium whitespace-nowrap"><%= subTotal %> total</span>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full border-collapse text-sm">
                            <thead>
                                <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50/80 dark:bg-gray-800/80">
                                    <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Code</th>
                                    <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Customer</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (subDistributors.length === 0) { %>
                                    <tr><td colspan="2" class="py-12 text-center text-sm text-gray-400 dark:text-gray-500">No sub distributors configured.</td></tr>
                                <% } %>
                                <% subDistributors.forEach(function(sd, idx) { %>
                                    <tr class="<%= idx % 2 === 1 ? 'bg-gray-100 dark:bg-gray-800' : 'bg-white dark:bg-[var(--surface-primary)]' %> border-b border-gray-100 dark:border-gray-700 last:border-0 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors"
                                        x-show="!search || '<%= (sd.customerCode || '').toLowerCase() %>'.includes(search.toLowerCase()) || '<%= (sd.customerName || '').toLowerCase().replace(/'/g, "\\'") %>'.includes(search.toLowerCase())">
                                        <td class="px-2 py-1.5 whitespace-nowrap"><span class="text-[11px] text-gray-400 dark:text-gray-500 font-mono"><%= sd.customerCode %></span></td>
                                        <td class="px-2 py-1.5"><span class="text-xs font-semibold text-gray-900 dark:text-gray-100"><% if (sd.customerName) { %><%= sd.customerName %><% } else { %><span class="text-gray-300">—</span><% } %></span></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

        </div>
    </main>

<%- include('../partials/layout_bottom') %>
