<!-- Invoice detail rows for a single customer -->
<%
  var custCode    = customerCode || (invoices[0] && invoices[0].customerCode) || '';
  var custName    = customerName || (invoices[0] && invoices[0].customerName) || custCode;
  var custMobile  = mobileNo || '';
  var safeCode    = custCode.replace(/[^a-zA-Z0-9]/g, '_');
  var activeInvs  = invoices.filter(function(i){ return i.status === 'ACTIVE'; });

  // Serialise invoice data for Alpine
  var invData = JSON.stringify(activeInvs.map(function(i){
      return {
          id: i.id,
          invoiceNo: i.invoiceNo,
          invoiceDate: fmtDate(i.invoiceDate),
          invoiceAmount: i.invoiceAmount || i.balanceAmount,
          paidAmount: i.paidAmount || 0,
          balanceAmount: i.balanceAmount,
          agingDays: i.agingDays
      };
  }));
%>

<div x-data='(function(){
  var invs    = <%= invData %>;
  var code    = "<%= custCode %>";
  var name    = "<%= custName.replace(/"/g, "\\\"") %>";
  var mobile  = "<%= custMobile %>";

  return {
    invs: invs,
    selected: [],
    get allSelected(){ return this.invs.length > 0 && this.selected.length === this.invs.length; },
    toggleAll(){
      if(this.allSelected) this.selected = [];
      else this.selected = this.invs.map(function(i){ return i.id; });
    },
    toggle(id){
      var idx = this.selected.indexOf(id);
      if(idx === -1) this.selected.push(id);
      else this.selected.splice(idx,1);
    },
    isSelected(id){ return this.selected.indexOf(id) !== -1; },
    get selInvs(){ var s=this.selected; return this.invs.filter(function(i){ return s.indexOf(i.id)!==-1; }); },
    get statementUrl(){
      var ids = this.selected.length ? this.selected.join(",") : "";
      return "/ar/customers/"+code+"/statement"+(ids?"?inv="+ids:"");
    }
  };
})()'
>

<!-- Toolbar -->
<div class="px-3 py-2 bg-gray-50 dark:bg-gray-800 border-b border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1.5 sm:gap-3">
  <!-- Left: Select all -->
  <label class="flex items-center gap-1.5 cursor-pointer select-none shrink-0">
    <input type="checkbox" class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer"
      :checked="allSelected" @change="toggleAll()">
    <span class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 whitespace-nowrap">
      <span x-text="selected.length ? selected.length+' selected' : 'Select all'"></span>
    </span>
  </label>
  <!-- Middle: Group info + controls -->
  <div x-data="{ grp: '', saving: false }" class="flex items-center gap-1.5 min-w-0 sm:flex-1">
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <select x-model="grp" class="rounded-md border-0 py-0.5 pl-2 pr-6 text-[10px] text-gray-700 dark:text-[var(--input-text)] ring-1 ring-inset ring-gray-200 dark:ring-gray-700 focus:ring-indigo-400 bg-white dark:bg-[var(--input-bg)] w-28">
      <option value=""><%= (typeof currentGroup !== 'undefined' && currentGroup) ? 'Move…' : 'Group…' %></option>
      <% if (typeof allGroups !== 'undefined') { allGroups.forEach(function(g) { %>
      <option value="<%= g %>"><%= g %></option>
      <% }); } %>
    </select>
    <button type="button" :disabled="!grp || saving"
      data-code="<%= encodeURIComponent(custCode) %>"
      @click="const _c=$el.dataset.code,_u='/admin/groups/'+encodeURIComponent(grp)+'/add-member',_b='customerCode='+_c;saving=true;fetch(_u,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:_b}).then(async r=>{if(r.ok){location.reload();}else if(r.status===409){const cur=await r.text();saving=false;if(confirm('Currently in '+cur+'. Move to selected group?')){saving=true;fetch(_u,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:_b+'&force=true'}).then(r2=>{if(r2.ok)location.reload();else saving=false;});}}else{saving=false;}})"
      class="shrink-0 px-1.5 py-0.5 rounded-md bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 text-[10px] font-semibold hover:bg-indigo-100 dark:hover:bg-indigo-900 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
      <span x-text="saving ? '…' : 'Set'"></span>
    </button>
    <% if (typeof currentGroup !== 'undefined' && currentGroup) { %>
    <button type="button"
      data-code="<%= encodeURIComponent(custCode) %>"
      @click="if(confirm('Remove from group?')) fetch('/admin/groups/member/'+$el.dataset.code+'/remove',{method:'POST'}).then(r=>{if(r.ok) location.reload()})"
      class="shrink-0 p-0.5 rounded text-gray-300 hover:text-red-500 transition-colors" title="Remove from group">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <% } %>
    <% } %>
  </div>
  <!-- Right: Statement -->
  <a :href="statementUrl"
    class="inline-flex items-center gap-1 px-2 py-1 rounded-md bg-violet-50 dark:bg-violet-950 hover:bg-violet-100 dark:hover:bg-violet-900 text-violet-700 dark:text-violet-400 text-[10px] font-semibold transition-colors border border-violet-200 dark:border-violet-800 shrink-0 self-start sm:self-auto">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    Statement
  </a>
</div>

<!-- Invoice Table -->
<div class="overflow-x-hidden sm:overflow-x-auto">
<style>
    @media(max-width:639px) {
        .inv-tbl { table-layout:fixed !important; width:100% !important; }
        .inv-tbl td, .inv-tbl th { padding:2px 3px !important; font-size:10px !important; overflow:hidden; white-space:nowrap; }
        .inv-tbl .inv-aging { padding:1px 4px !important; font-size:9px !important; }
        .inv-hide-sm { display:none !important; width:0 !important; padding:0 !important; }
        /* zero out all hidden columns (location uses hidden class, not inv-hide-sm) */
        .inv-tbl th:nth-child(4), .inv-tbl td:nth-child(4) { display:none !important; width:0 !important; padding:0 !important; }
        /* col 1=checkbox, 2=invoice no, 3=date, 4=location(hidden), 5=inv amt, 6=paid(hidden), 7=outstanding(hidden), 8=aging */
        /* proportional widths — browser scales these to fill 100% */
        .inv-tbl col:nth-child(1) { width:20px !important; }
        .inv-tbl col:nth-child(2) { width:130px !important; }
        .inv-tbl col:nth-child(3) { width:90px !important; }
        .inv-tbl th:nth-child(3), .inv-tbl td:nth-child(3) { text-align:center !important; }
        .inv-tbl col:nth-child(4) { width:0 !important; }
        .inv-tbl col:nth-child(5) { width:105px !important; }
        .inv-tbl th:nth-child(5) { text-align:center !important; }
        .inv-tbl col:nth-child(6) { width:0 !important; }
        .inv-tbl col:nth-child(7) { width:0 !important; }
        .inv-tbl col:nth-child(8) { width:42px !important; }
    }
</style>
<table class="inv-tbl w-full border-collapse text-sm table-fixed">
    <colgroup>
        <col class="w-8">
        <col class="w-32">
        <col class="w-24">
        <col class="w-28">
        <col class="w-28">
        <col class="w-24">
        <col class="w-28">
        <col class="w-20">
    </colgroup>
    <thead>
        <tr class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
            <th scope="col" class="py-2 px-3 w-8"></th>
            <th scope="col" class="py-2 px-3 text-center text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Invoice No</th>
            <th scope="col" class="py-2 px-3 text-center text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Date</th>
            <th scope="col" class="py-2 px-3 text-center text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider hidden sm:table-cell">Location</th>
            <th scope="col" class="py-2 px-3 text-right text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Invoice Amt</th>
            <th scope="col" class="inv-hide-sm py-2 px-3 text-right text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Paid</th>
            <th scope="col" class="inv-hide-sm py-2 px-3 text-right text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Outstanding</th>
            <th scope="col" class="py-2 px-3 text-center text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Aging</th>
        </tr>
    </thead>
    <tbody>
        <% const fmt=new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR' }); %>
        <% var invIdx = 0; %>
        <% invoices.forEach(function(inv) {
            invIdx++;
            const invRowBase = invIdx % 2 === 0 ? 'bg-gray-100 dark:bg-gray-800' : 'bg-white dark:bg-[var(--surface-primary)]';
            let badgeColor='bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400';
            if (inv.agingDays > 90) badgeColor = 'bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-400';
            else if (inv.agingDays > 60) badgeColor = 'bg-orange-50 text-orange-700 dark:bg-orange-950 dark:text-orange-400';
            else if (inv.agingDays > 30) badgeColor = 'bg-yellow-50 text-yellow-700 dark:bg-yellow-950 dark:text-yellow-400';
            else if (inv.agingDays > 0) badgeColor = 'bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-400';
            else badgeColor = 'bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-400';
        %>
        <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0 <%= inv.status === 'SETTLED' ? 'bg-emerald-50/50 dark:bg-emerald-900/20 hover:bg-emerald-50/80 dark:hover:bg-emerald-900/30' : invRowBase + ' hover:bg-indigo-50/30 dark:hover:bg-indigo-900/20' %> transition-colors"
            <% if (inv.status === 'ACTIVE') { %>:class="isSelected('<%= inv.id %>') ? 'bg-indigo-50/40' : ''"<% } %>>
            <td class="py-2 px-3">
                <% if (inv.status === 'ACTIVE') { %>
                <input type="checkbox" class="w-3.5 h-3.5 rounded accent-indigo-600 cursor-pointer"
                    :checked="isSelected('<%= inv.id %>')"
                    @change="toggle('<%= inv.id %>')">
                <% } %>
            </td>
            <td class="py-2 px-3 text-center text-gray-700 dark:text-gray-300 font-mono">
                <%= inv.invoiceNo || '-' %>
                <% if (inv.status === 'SETTLED') { %>
                    <span class="inline-flex items-center rounded-md bg-emerald-50 dark:bg-emerald-950 px-1.5 py-0.5 text-[9px] font-bold text-emerald-700 dark:text-emerald-400 ring-1 ring-inset ring-emerald-600/20 dark:ring-emerald-800">✓ Settled</span>
                <% } %>
            </td>
            <td class="py-2 px-3 text-center text-gray-500 dark:text-gray-400"><%= fmtDate(inv.invoiceDate) %></td>
            <td class="py-2 px-3 text-center hidden sm:table-cell">
                <% if (inv.siteName) { %>
                    <span class="inline-flex items-center rounded-full bg-violet-50 dark:bg-violet-950 border border-violet-200 dark:border-violet-800 px-2 py-0.5 text-[10px] font-semibold text-violet-700 dark:text-violet-400"><%= inv.siteName %></span>
                <% } else { %>
                    <span class="text-[10px] text-gray-300">—</span>
                <% } %>
            </td>
            <td class="py-2 px-3 text-gray-400 dark:text-gray-500 text-right"><%= fmt.format(inv.invoiceAmount || inv.balanceAmount) %></td>
            <td class="inv-hide-sm py-2 px-3 text-emerald-600 font-medium text-right"><%= fmt.format(inv.paidAmount || 0) %></td>
            <td class="inv-hide-sm py-2 px-3 text-gray-900 dark:text-gray-100 font-bold text-right"><%= fmt.format(inv.balanceAmount) %></td>
            <td class="py-2 px-3 text-center">
                <span class="inv-aging inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= badgeColor %>"><%= inv.agingDays %></span>
            </td>
        </tr>
        <% }); %>
    </tbody>
    <tfoot>
        <%
            var _totalInvAmt = 0, _totalPaid = 0, _totalOutstanding = 0;
            invoices.forEach(function(inv) {
                _totalInvAmt     += (inv.invoiceAmount || inv.balanceAmount || 0);
                _totalPaid       += (inv.paidAmount || 0);
                _totalOutstanding += (inv.balanceAmount || 0);
            });
        %>
        <tr class="bg-indigo-50/60 dark:bg-indigo-900/20 border-t-2 border-indigo-200 dark:border-indigo-800">
            <td class="py-2.5 px-3"></td>
            <td class="py-2.5 px-3 text-center text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider" colspan="2">Total (<%= invoices.length %> invoices)</td>
            <td class="py-2.5 px-3 hidden sm:table-cell"></td>
            <td class="py-2.5 px-3 text-right text-xs font-bold text-gray-700 dark:text-gray-300"><%= fmt.format(_totalInvAmt) %></td>
            <td class="inv-hide-sm py-2.5 px-3 text-right text-xs font-bold text-emerald-700"><%= fmt.format(_totalPaid) %></td>
            <td class="inv-hide-sm py-2.5 px-3 text-right text-xs font-extrabold text-gray-900 dark:text-gray-100"><%= fmt.format(_totalOutstanding) %></td>
            <td class="py-2.5 px-3"></td>
        </tr>
    </tfoot>
</table>
</div>

<!-- Collection Notes Section -->
<!-- Dispute action -->
<div id="dispute-btn-<%= safeCode %>" class="px-3 py-1.5 border-t border-gray-100 dark:border-gray-700 flex items-center justify-center sm:justify-end">
    <% if (!isDisputed) { %>
    <button hx-post="/ar/customers/<%= encodeURIComponent(custCode) %>/dispute"
        hx-target="#dispute-btn-<%= safeCode %>" hx-swap="innerHTML"
        hx-confirm="Mark this customer as disputed? This will flag them on the dashboard."
        class="inline-flex items-center gap-1 px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-red-50 dark:bg-red-950 hover:bg-red-100 dark:hover:bg-red-900 text-red-600 dark:text-red-400 text-[10px] sm:text-[11px] font-semibold transition-colors border border-red-200 dark:border-red-800">
        <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        Mark as Disputed
    </button>
    <% } else if (userRole === 'ADMIN' || userRole === 'MANAGER') { %>
    <button hx-post="/ar/customers/<%= encodeURIComponent(custCode) %>/dispute"
        hx-target="#dispute-btn-<%= safeCode %>" hx-swap="innerHTML"
        hx-confirm="Remove dispute for this customer?"
        class="inline-flex items-center gap-1 px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-orange-100 dark:bg-orange-950 hover:bg-orange-200 dark:hover:bg-orange-900 text-orange-700 dark:text-orange-400 text-[10px] sm:text-[11px] font-semibold transition-colors border border-orange-300 dark:border-orange-800">
        <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Disputed — Remove
    </button>
    <% } else { %>
    <span class="inline-flex items-center gap-1 px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-orange-100 dark:bg-orange-950 text-orange-700 dark:text-orange-400 text-[10px] sm:text-[11px] font-semibold border border-orange-300 dark:border-orange-800">
        <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        Disputed
    </span>
    <% } %>
</div>

<% if (locals.hasModule && locals.hasModule('ar_pending_settlement')) { %>
<div class="border-t border-gray-200 dark:border-gray-700">
    <div class="px-3 py-2.5 flex items-center gap-2 bg-gray-50/80 dark:bg-gray-800/80">
        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <span class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Pending Settlement</span>
    </div>
    <div class="px-3 pb-3 overflow-x-auto"
        hx-get="/ar/customers/<%= encodeURIComponent(custCode) %>/pending-settlement"
        hx-trigger="load" hx-swap="innerHTML">
        <div class="flex justify-center py-4">
            <svg class="animate-spin w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                <path class="opacity-100" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
        </div>
    </div>
</div>
<% } %>

<% if (invoices.length > 0) { %>
    <div class="border-t border-gray-200 dark:border-gray-700 mt-1">
        <div class="px-3 py-2.5 flex items-center justify-between bg-gray-50/80 dark:bg-gray-800/80">
            <div class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
                </svg>
                <span class="text-[11px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Collection Notes</span>
            </div>
        </div>
        <div id="comments-<%= safeCode %>" class="px-3 py-3" hx-get="/ar/comments/<%= encodeURIComponent(custCode) %>"
            hx-trigger="load" hx-swap="innerHTML">
            <div class="flex justify-center py-4">
                <svg class="animate-spin w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
                    <path class="opacity-100" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </div>
        </div>
    </div>
<% } %>

</div>
