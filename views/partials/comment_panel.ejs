<!-- Comment Panel Partial - loaded via HTMX into invoice_details -->

<div class="space-y-2 sm:space-y-4" aria-live="polite">

    <!-- Add Comment Form -->
    <% if (canPost) { %>
        <form hx-post="/ar/comments" hx-target="#comments-<%= customerCode.replace(/[^a-zA-Z0-9]/g, '_') %>"
            hx-swap="innerHTML" class="bg-white dark:bg-[var(--surface-primary)] rounded-lg border border-gray-200 dark:border-gray-700 p-2.5 sm:p-4 shadow-sm">
            <div class="flex items-start gap-2 sm:gap-3">
                <div class="hidden sm:flex h-8 w-8 rounded-full bg-gradient-to-tr from-indigo-500 to-blue-500 items-center justify-center text-white font-bold text-xs shadow-sm flex-shrink-0 mt-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z">
                        </path>
                    </svg>
                </div>
                <div class="flex-1 space-y-2">
                    <input type="hidden" name="customerCode" value="<%= customerCode %>">
                    <textarea name="comment" required rows="2"
                        placeholder="Add a note... (e.g., Customer requested 15-day extension, PDC received)"
                        class="block w-full rounded-lg border-0 py-1.5 px-2.5 text-xs sm:text-sm text-gray-900 dark:text-[var(--input-text)] shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-500 resize-none dark:bg-[var(--input-bg)]"></textarea>
                    <div class="flex items-center justify-between gap-2">
                        <div class="flex items-center gap-1.5">
                            <label for="followUp-<%= customerCode.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                class="text-[10px] sm:text-xs font-semibold text-gray-500 dark:text-gray-400 whitespace-nowrap flex items-center gap-1">
                                <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                                    </path>
                                </svg>
                                Follow-up
                            </label>
                            <input type="date" name="followUpDate"
                                id="followUp-<%= customerCode.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                class="rounded-lg border-0 py-1 px-1.5 text-[10px] sm:text-xs text-gray-700 dark:text-[var(--input-text)] shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-indigo-500 dark:bg-[var(--input-bg)]">
                        </div>
                        <button type="submit"
                            class="inline-flex items-center gap-1 rounded-lg bg-indigo-600 px-3 py-1.5 text-[10px] sm:text-xs font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                            </svg>
                            Post
                        </button>
                    </div>
                </div>
            </div>
        </form>
        <% } %>

            <!-- Admin: Delete All -->
            <% if (userRole === 'ADMIN' && comments.length > 0) { %>
            <div class="flex justify-end">
                <button
                    hx-post="/ar/comments/<%= customerCode %>/delete-all"
                    hx-target="#comments-<%= customerCode.replace(/[^a-zA-Z0-9]/g, '_') %>"
                    hx-swap="innerHTML"
                    hx-confirm="Delete ALL comments for this customer? This cannot be undone."
                    class="text-[10px] font-bold text-red-400 hover:text-red-600 uppercase tracking-wider transition-colors">
                    Delete All
                </button>
            </div>
            <% } %>

            <!-- Comment Timeline -->
            <% if (comments.length===0) { %>
                <div class="flex flex-col items-center justify-center py-3 sm:py-6 text-center">
                    <div class="p-2 bg-gray-50 dark:bg-gray-800 rounded-full mb-1.5">
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z">
                            </path>
                        </svg>
                    </div>
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400">No collection notes yet.</p>
                    <% if (canPost) { %>
                        <p class="text-[10px] text-gray-400 mt-0.5">Add the first note above.</p>
                        <% } %>
                </div>
                <% } else { %>
                    <div class="relative space-y-0">
                        <!-- Timeline line -->
                        <div class="absolute left-[15px] top-2 bottom-2 w-px bg-gray-200 dark:bg-gray-700"></div>

                        <% comments.forEach(function(c) { %>
                            <%- include('comment_node', { c, currentUserId, userRole, canPost, customerCode, depth: 0 }) %>
                        <% }); %>
                    </div>
                    <% } %>
</div>