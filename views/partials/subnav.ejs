<%
    const hm = locals.hasModule || function(){ return false; };
    const isAdmin = locals.user && locals.user.role === 'ADMIN';
    const canDashboard         = hm('ar_dashboard');
    const canDirectory         = hm('ar_directory');
    const canPendingSettlement = hm('ar_pending_settlement');
    const canUpload            = hm('ar_upload');
    const canAssignments       = hm('ar_assign');
    const canManageKA    = hm('admin_key_accounts');
    const canManageSD    = hm('admin_sub_distributors');
    const canSiteAssign  = hm('admin_site_assignments');
    const canGroupImport = hm('admin_group_import');
    const hasAnyAdmin    = canManageKA || canManageSD || isAdmin || canUpload || canAssignments || canSiteAssign || canGroupImport;
    const cp = locals.currentPath || '';

    const arChildActive    = cp.startsWith('/ar/directory') || cp.startsWith('/ar/groups');
    const adminChildActive = cp.startsWith('/admin') || cp.startsWith('/ar/upload') || cp.startsWith('/ar/assignments');
%>
<% if (locals.user && (canDashboard || canDirectory || canUpload || canAssignments || hasAnyAdmin)) { %>
<style>
    .dd-panel {
        transform-origin: top left;
        transition: opacity 0.15s ease, transform 0.15s ease;
    }
    .dd-panel[x-cloak], .dd-panel.entering { opacity: 0; transform: scale(0.95) translateY(-4px); }
    .dd-panel.entered  { opacity: 1; transform: scale(1) translateY(0); }
    .dd-panel.leaving  { opacity: 0; transform: scale(0.95) translateY(-4px); }
</style>

<nav class="relative" style="z-index:25">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">

        <!-- Desktop nav — now in header, hidden here -->
        <div class="hidden items-center justify-center gap-0.5 py-1.5" style="display:none !important">

            <%# ── Home ── %>
            <% if (canDashboard) { %>
            <a href="/ar"
               class="flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg font-medium transition-colors whitespace-nowrap
                      <%= cp === '/ar' ? 'bg-indigo-50 text-indigo-700 font-semibold' : 'text-gray-500 hover:bg-gray-100 hover:text-gray-700' %>">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                Home
            </a>
            <% } %>

            <%# ── AR dropdown (Customers + Groups) ── %>
            <% if (canDirectory) { %>
            <div class="relative" x-data="{ open: false }" @click.outside="open = false" @keydown.escape.window="open = false">
                <button @click="open = !open"
                        class="flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg font-medium transition-colors whitespace-nowrap
                               <%= arChildActive ? 'bg-indigo-50 text-indigo-700 font-semibold' : 'text-gray-500 hover:bg-gray-100 hover:text-gray-700' %>">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    AR
                    <svg class="w-3 h-3 flex-shrink-0 transition-transform duration-200" :class="open ? 'rotate-180' : ''"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div x-show="open" x-cloak
                     x-transition:enter="transition ease-out duration-150"
                     x-transition:enter-start="opacity-0 -translate-y-1 scale-95"
                     x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                     x-transition:leave="transition ease-in duration-100"
                     x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                     x-transition:leave-end="opacity-0 -translate-y-1 scale-95"
                     class="absolute left-0 top-full mt-1.5 w-44 bg-white rounded-xl border border-gray-100 py-1.5"
                     style="box-shadow:0 10px 40px rgba(0,0,0,0.10),0 2px 8px rgba(0,0,0,0.06);z-index:50;transform-origin:top left">

                    <a href="/ar/directory" @click="open = false"
                       class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                              <%= cp.startsWith('/ar/directory') ? 'bg-indigo-50 text-indigo-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Customers
                    </a>
                    <a href="/ar/groups" @click="open = false"
                       class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                              <%= cp.startsWith('/ar/groups') ? 'bg-indigo-50 text-indigo-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                        Groups
                    </a>
                </div>
            </div>
            <% } %>



            <%# ── Admin dropdown ── %>
            <% if (hasAnyAdmin) { %>
            <div class="w-px h-5 bg-gray-200 mx-1.5 flex-shrink-0"></div>
            <div class="relative" x-data="{ open: false }" @click.outside="open = false" @keydown.escape.window="open = false">
                <button @click="open = !open"
                        class="flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg font-medium transition-colors whitespace-nowrap
                               <%= adminChildActive ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-400 hover:bg-gray-100 hover:text-violet-600' %>">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Settings
                    <svg class="w-3 h-3 flex-shrink-0 transition-transform duration-200" :class="open ? 'rotate-180' : ''"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div x-show="open" x-cloak
                     x-transition:enter="transition ease-out duration-150"
                     x-transition:enter-start="opacity-0 -translate-y-1 scale-95"
                     x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                     x-transition:leave="transition ease-in duration-100"
                     x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                     x-transition:leave-end="opacity-0 -translate-y-1 scale-95"
                     class="absolute left-0 top-full mt-1.5 w-48 bg-white rounded-xl border border-gray-100 py-1.5"
                     style="box-shadow:0 10px 40px rgba(0,0,0,0.10),0 2px 8px rgba(0,0,0,0.06);z-index:50;transform-origin:top left">

                    <% if (canUpload) { %>
                    <a href="/ar/upload" @click="open = false"
                       class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                              <%= cp.startsWith('/ar/upload') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                        </svg>
                        Upload
                    </a>
                    <% } %>
                    <% if (canAssignments) { %>
                    <a href="/ar/assignments" @click="open = false"
                       class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                              <%= cp.startsWith('/ar/assignments') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        CO Assign
                    </a>
                    <% } %>
                    <% if (canManageKA || canManageSD) { %>
                    <a href="/admin/categories" @click="open = false"
                       class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                              <%= cp.startsWith('/admin/categories') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
                        </svg>
                        Categories
                    </a>
                    <% } %>
                    <% if (isAdmin || canSiteAssign || canGroupImport) { %>
                        <% if (canManageKA || canManageSD) { %>
                        <div class="h-px bg-gray-100 my-1.5 mx-3"></div>
                        <% } %>
                        <% if (isAdmin) { %>
                        <a href="/admin/users" @click="open = false"
                           class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                                  <%= cp.startsWith('/admin/users') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                            Users
                        </a>
                        <% } %>
                        <% if (canSiteAssign) { %>
                        <a href="/admin/site-assignments" @click="open = false"
                           class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                                  <%= cp.startsWith('/admin/site-assignments') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                            </svg>
                            Change Code Location
                        </a>
                        <% } %>
                        <% if (canGroupImport) { %>
                        <a href="/admin/group-import" @click="open = false"
                           class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                                  <%= cp.startsWith('/admin/group-import') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
                            </svg>
                            Group Import
                        </a>
                        <% } %>
                        <% if (isAdmin) { %>
                        <a href="/admin/branding" @click="open = false"
                           class="flex items-center gap-2.5 mx-1.5 px-3 py-2 text-sm rounded-lg transition-colors
                                  <%= cp.startsWith('/admin/branding') ? 'bg-violet-50 text-violet-700 font-semibold' : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900' %>">
                            <svg class="w-3.5 h-3.5 flex-shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            Branding
                        </a>
                        <% } %>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>

    <!-- ── Mobile drawer ── -->
    <template x-teleport="body">
        <div x-show="$store.nav.open" x-cloak class="sm:hidden" style="position:fixed;inset:0;z-index:40;display:flex">

            <!-- Backdrop -->
            <div @click="$store.nav.open = false"
                 x-transition:enter="transition-opacity duration-200"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="transition-opacity duration-150"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"
                 style="position:absolute;inset:0;background:rgba(0,0,0,0.5)"></div>

            <!-- Drawer panel -->
            <div x-transition:enter="transition-transform duration-250 ease-out"
                 x-transition:enter-start="-translate-x-full"
                 x-transition:enter-end="translate-x-0"
                 x-transition:leave="transition-transform duration-200 ease-in"
                 x-transition:leave-start="translate-x-0"
                 x-transition:leave-end="-translate-x-full"
                 style="position:relative;width:72vw;max-width:280px;background:var(--surface-primary);height:100%;display:flex;flex-direction:column;box-shadow:4px 0 24px rgba(0,0,0,0.15)">

                <!-- Drawer header -->
                <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 16px 12px;border-bottom:1px solid var(--border-subtle)">
                    <div style="display:flex;align-items:center;gap:8px">
                        <img src="/kosca-logo.png" alt="Kosca" style="height:28px;width:28px;object-fit:contain">
                        <span style="font-size:15px;font-weight:700;color:var(--text-primary);letter-spacing:-0.01em">Kosca Distribution LLP</span>
                    </div>
                    <button @click="$store.nav.open = false"
                            style="padding:6px;border-radius:8px;color:var(--text-light);border:none;background:none;cursor:pointer;line-height:0"
                            onmouseover="this.style.background='var(--dropdown-hover)'" onmouseout="this.style.background='none'">
                        <svg style="width:18px;height:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <!-- Nav links -->
                <div style="flex:1;overflow-y:auto;padding:10px">

                    <!-- Home -->
                    <% if (canDashboard) { %>
                    <a href="/ar" @click="$store.nav.open = false"
                       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:14px;
                              font-weight:<%= cp === '/ar' ? '600' : '500' %>;
                              color:<%= cp === '/ar' ? 'var(--text-tertiary)' : 'var(--text-primary)' %>;
                              background:<%= cp === '/ar' ? 'var(--surface-tertiary)' : 'transparent' %>;
                              text-decoration:none;margin-bottom:2px">
                        <svg style="width:15px;height:15px;flex-shrink:0;opacity:0.7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                        </svg>
                        Home
                    </a>
                    <% } %>

                    <!-- AR section (collapsible) -->
                    <% if (canDirectory) { %>
                    <div x-data="{ open: <%= arChildActive ? 'true' : 'false' %> }">
                        <button @click="open = !open"
                                style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:14px;width:100%;text-align:left;border:none;cursor:pointer;
                                       font-weight:<%= arChildActive ? '600' : '500' %>;
                                       color:<%= arChildActive ? 'var(--text-tertiary)' : 'var(--text-primary)' %>;
                                       background:<%= arChildActive ? 'var(--surface-tertiary)' : 'transparent' %>;
                                       margin-bottom:2px">
                            <svg style="width:15px;height:15px;flex-shrink:0;opacity:0.7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span style="flex:1">AR</span>
                            <svg width="12" height="12" style="flex-shrink:0;transition:transform 0.2s" :style="open ? 'transform:rotate(180deg)' : ''"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div x-show="open" x-transition style="padding-left:14px;margin-bottom:2px">
                            <a href="/ar/directory" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/ar/directory') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/ar/directory') ? 'var(--text-tertiary)' : 'var(--text-primary)' %>;
                                      background:<%= cp.startsWith('/ar/directory') ? 'var(--surface-tertiary)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                Customers
                            </a>
                            <a href="/ar/groups" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/ar/groups') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/ar/groups') ? 'var(--text-tertiary)' : 'var(--text-primary)' %>;
                                      background:<%= cp.startsWith('/ar/groups') ? 'var(--surface-tertiary)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                                </svg>
                                Groups
                            </a>
                        </div>
                    </div>
                    <% } %>

                    <!-- Pending Settlement -->
                    <% if (canPendingSettlement) { %>
                    <a href="/ar/pending-settlement" @click="$store.nav.open = false"
                       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:14px;
                              font-weight:<%= cp.startsWith('/ar/pending-settlement') ? '600' : '500' %>;
                              color:<%= cp.startsWith('/ar/pending-settlement') ? 'var(--text-tertiary)' : 'var(--text-primary)' %>;
                              background:<%= cp.startsWith('/ar/pending-settlement') ? 'var(--surface-tertiary)' : 'transparent' %>;
                              text-decoration:none;margin-bottom:2px">
                        <svg style="width:15px;height:15px;flex-shrink:0;opacity:0.7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Pending Settlement
                    </a>
                    <% } %>

                    <!-- Admin section (collapsible) -->
                    <% if (hasAnyAdmin) { %>
                    <div style="margin:10px 0 4px 4px;padding:0 8px">
                        <div style="height:1px;background:var(--border-subtle)"></div>
                    </div>
                    <div x-data="{ open: <%= adminChildActive ? 'true' : 'false' %> }">
                        <button @click="open = !open"
                                style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:14px;width:100%;text-align:left;border:none;cursor:pointer;
                                       font-weight:<%= adminChildActive ? '600' : '500' %>;
                                       color:<%= adminChildActive ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                       background:<%= adminChildActive ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                       margin-bottom:2px">
                            <svg style="width:15px;height:15px;flex-shrink:0;opacity:0.7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span style="flex:1">Settings</span>
                            <svg width="12" height="12" style="flex-shrink:0;transition:transform 0.2s" :style="open ? 'transform:rotate(180deg)' : ''"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div x-show="open" x-transition style="padding-left:14px;margin-bottom:2px">
                            <% if (canUpload) { %>
                            <a href="/ar/upload" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/ar/upload') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/ar/upload') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/ar/upload') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                                </svg>
                                Upload
                            </a>
                            <% } %>
                            <% if (canAssignments) { %>
                            <a href="/ar/assignments" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/ar/assignments') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/ar/assignments') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/ar/assignments') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                                CO Assign
                            </a>
                            <% } %>
                            <% if (canManageKA || canManageSD) { %>
                            <a href="/admin/categories" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/admin/categories') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/admin/categories') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/admin/categories') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
                                </svg>
                                Categories
                            </a>
                            <% } %>
                            <% if (isAdmin) { %>
                            <a href="/admin/users" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/admin/users') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/admin/users') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/admin/users') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                                </svg>
                                Users
                            </a>
                            <% } %>
                            <% if (canSiteAssign) { %>
                            <a href="/admin/site-assignments" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/admin/site-assignments') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/admin/site-assignments') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/admin/site-assignments') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                                </svg>
                                Change Code Location
                            </a>
                            <% } %>
                            <% if (canGroupImport) { %>
                            <a href="/admin/group-import" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/admin/group-import') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/admin/group-import') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/admin/group-import') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
                                </svg>
                                Group Import
                            </a>
                            <% } %>
                            <% if (isAdmin) { %>
                            <a href="/admin/branding" @click="$store.nav.open = false"
                               style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:10px;font-size:13.5px;
                                      font-weight:<%= cp.startsWith('/admin/branding') ? '600' : '500' %>;
                                      color:<%= cp.startsWith('/admin/branding') ? 'var(--dropdown-active-text)' : 'var(--text-light)' %>;
                                      background:<%= cp.startsWith('/admin/branding') ? 'var(--dropdown-active-bg)' : 'transparent' %>;
                                      text-decoration:none;margin-bottom:2px">
                                <svg style="width:14px;height:14px;flex-shrink:0;opacity:0.6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                Branding
                            </a>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>

                <!-- Sync info -->
                <% if (locals.syncInfo) { %>
                <% const _si = locals.syncInfo; %>
                <% if (_si.arImportedAt || _si.cmImportedAt) { %>
                <div style="padding:8px 16px;border-top:1px solid var(--border-subtle);display:flex;gap:16px">
                    <% if (_si.arImportedAt) { %>
                    <div>
                        <div style="font-size:8px;font-weight:700;color:var(--accent-secondary);text-transform:uppercase;letter-spacing:0.05em">AR</div>
                        <div style="font-size:10px;font-weight:500;color:var(--text-tertiary)"><%= _si.arImportedAt %></div>
                    </div>
                    <% } %>
                    <% if (_si.cmImportedAt) { %>
                    <div>
                        <div style="font-size:8px;font-weight:700;color:var(--accent-secondary);text-transform:uppercase;letter-spacing:0.05em">CM</div>
                        <div style="font-size:10px;font-weight:500;color:var(--text-tertiary)"><%= _si.cmImportedAt %></div>
                    </div>
                    <% } %>
                </div>
                <% } %>
                <% } %>

                <!-- User info at bottom -->
                <div style="padding:12px 16px;border-top:1px solid var(--border-subtle);display:flex;align-items:center;gap:10px">
                    <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--accent-gradient-from),var(--accent-gradient-to));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:12px;flex-shrink:0">
                        <%= locals.user.name.charAt(0).toUpperCase() %>
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:13px;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= locals.user.name %></div>
                        <div style="font-size:10px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:0.06em"><%= locals.user.role %></div>
                    </div>
                    <a href="/logout" style="color:var(--text-light);line-height:0" title="Sign Out">
                        <svg style="width:15px;height:15px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </template>
</nav>
<% } %>
